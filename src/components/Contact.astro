---
import { site } from "@config/site";
const { contact } = site;
const info = contact.info;
const waNumber = info.whatsapp ?? info.phoneRaw;
---

<section class="section contact" id="contacto">
  <div class="container contact__inner">
    <div class="contact__left" data-reveal>
      <p class="eyebrow">{contact.eyebrow}</p>
      <h2 class="display-lg contact__title">{contact.title}</h2>
      <p class="lead contact__intro">{contact.intro}</p>

      <ul class="info">
        <li class="info__row">
          <span class="info__k">Teléfono</span>
          <a class="info__v link-underline" href={`tel:${info.phoneRaw}`}>{info.phone}</a>
        </li>
        <li class="info__row">
          <span class="info__k">Email</span>
          <a class="info__v link-underline" href={`mailto:${info.email}`}>{info.email}</a>
        </li>
        <li class="info__row">
          <span class="info__k">Despacho</span>
          <span class="info__v">{info.addressLine}<br />{info.postalCode} {info.city}</span>
        </li>
        <li class="info__row">
          <span class="info__k">Horario</span>
          <span class="info__v">{info.hours}</span>
        </li>
      </ul>

      <a class="wa" href={`https://wa.me/${waNumber}`} target="_blank" rel="noopener">
        <span class="wa__dot" aria-hidden="true"></span>
        Escríbanos por WhatsApp
      </a>
    </div>

    <div class="contact__right" data-reveal style="--reveal-delay:.12s">
      <form class="form" data-form>
        <div class="field">
          <label for="name">Nombre y apellidos</label>
          <input id="name" name="name" type="text" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Correo electrónico</label>
          <input id="email" name="email" type="email" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="phone">Teléfono</label>
          <input id="phone" name="phone" type="tel" autocomplete="tel" />
        </div>
        <div class="field">
          <label for="message">¿En qué podemos ayudarle?</label>
          <textarea id="message" name="message" rows="4" required></textarea>
        </div>
        <label class="consent">
          <input type="checkbox" required />
          <span>He leído y acepto la política de privacidad.</span>
        </label>
        <button type="submit" class="btn form__btn">
          Enviar consulta <span class="arrow" aria-hidden="true">→</span>
        </button>
        <p class="form__note" data-form-note hidden></p>
      </form>
    </div>
  </div>

  {info.mapEmbed && (
    <div class="container">
      <div class="map" data-reveal>
        <iframe
          src={info.mapEmbed}
          title={`Ubicación de ${site.brand.name}`}
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
    </div>
  )}
</section>

<style>
  .contact__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: clamp(2rem, 6vw, 5.5rem);
    align-items: start;
  }
  .contact__title {
    margin-top: 1.3rem;
    max-width: 12ch;
  }
  .contact__intro {
    margin-top: 1.4rem;
    max-width: 42ch;
  }
  .info {
    list-style: none;
    padding: 0;
    margin: 2.6rem 0 0;
    border-top: 1px solid var(--line);
  }
  .info__row {
    display: grid;
    grid-template-columns: 8rem 1fr;
    gap: 1rem;
    padding: 1.1rem 0;
    border-bottom: 1px solid var(--line);
    align-items: baseline;
  }
  .info__k {
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
  }
  .info__v {
    font-size: 1.05rem;
    color: var(--ink);
  }
  .wa {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    margin-top: 1.8rem;
    font-size: 0.95rem;
    color: var(--accent);
  }
  .wa__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--accent-2);
    box-shadow: 0 0 0 0 var(--accent-2);
    animation: pulse 2.4s infinite;
  }
  @keyframes pulse {
    0% { box-shadow: 0 0 0 0 color-mix(in srgb, var(--accent-2) 60%, transparent); }
    70% { box-shadow: 0 0 0 8px transparent; }
    100% { box-shadow: 0 0 0 0 transparent; }
  }

  .form {
    background: var(--paper-2);
    border: 1px solid var(--line);
    border-radius: 3px;
    padding: clamp(1.6rem, 3vw, 2.4rem);
    display: flex;
    flex-direction: column;
    gap: 1.1rem;
  }
  .field {
    display: flex;
    flex-direction: column;
    gap: 0.45rem;
  }
  .field label {
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--ink-soft);
  }
  .field input,
  .field textarea {
    font-family: var(--font-body);
    font-size: 1rem;
    color: var(--ink);
    background: var(--paper);
    border: 1px solid var(--line-strong);
    border-radius: 2px;
    padding: 0.75rem 0.85rem;
    transition: border-color 0.3s ease, box-shadow 0.3s ease;
    resize: vertical;
  }
  .field input:focus,
  .field textarea:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 3px color-mix(in srgb, var(--accent) 16%, transparent);
  }
  .consent {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.85rem;
    color: var(--ink-soft);
  }
  .consent input {
    margin-top: 0.2rem;
    accent-color: var(--accent);
  }
  .form__btn {
    justify-content: center;
    margin-top: 0.4rem;
  }
  .form__note {
    font-size: 0.9rem;
    text-align: center;
    margin-top: 0.2rem;
    color: var(--accent);
  }

  .map {
    margin-top: clamp(2.5rem, 5vw, 4rem);
    border: 1px solid var(--line);
    border-radius: 3px;
    overflow: hidden;
    filter: grayscale(0.3) contrast(1.05);
  }
  .map iframe {
    width: 100%;
    height: 360px;
    border: 0;
    display: block;
  }

  @media (max-width: 820px) {
    .contact__inner {
      grid-template-columns: 1fr;
    }
  }
</style>

<script is:inline define:vars={{ email: info.email, brandName: site.brand.name }}>
  // Sin backend: el formulario compone un mailto. Para producción, conecta
  // el form a un servicio (Formspree, Resend, etc.) cambiando este handler.
  const form = document.querySelector("[data-form]");
  const note = document.querySelector("[data-form-note]");
  form?.addEventListener("submit", (e) => {
    e.preventDefault();
    const data = new FormData(form);
    const subject = encodeURIComponent(`Consulta web — ${data.get("name") || ""}`);
    const body = encodeURIComponent(
      `Nombre: ${data.get("name")}\n` +
        `Email: ${data.get("email")}\n` +
        `Teléfono: ${data.get("phone") || "—"}\n\n` +
        `${data.get("message")}\n\n— Enviado desde ${brandName}`
    );
    window.location.href = `mailto:${email}?subject=${subject}&body=${body}`;
    if (note) {
      note.hidden = false;
      note.textContent = "Abriendo su cliente de correo… Si no se abre, escríbanos a " + email;
    }
  });
</script>

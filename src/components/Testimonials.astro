---
import { site } from "@config/site";
const { testimonials } = site;
---

<section class="section" id="opiniones">
  <div class="container">
    <div class="tst__head" data-reveal>
      <p class="eyebrow">{testimonials.eyebrow}</p>
      <h2 class="display-lg">{testimonials.title}</h2>
    </div>

    <div class="tst__grid">
      {testimonials.items.map((t, i) => (
        <figure class="quote" data-reveal style={`--reveal-delay:${i * 0.1}s`}>
          <span class="quote__mark" aria-hidden="true">“</span>
          <blockquote class="quote__text">{t.quote}</blockquote>
          <figcaption class="quote__cite">
            <span class="quote__author">{t.author}</span>
            <span class="quote__context">{t.context}</span>
          </figcaption>
        </figure>
      ))}
    </div>
  </div>
</section>

<style>
  .tst__head {
    margin-bottom: clamp(2.5rem, 5vw, 4rem);
  }
  .tst__head h2 {
    margin-top: 1.3rem;
    max-width: 16ch;
  }
  .tst__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: clamp(1.5rem, 3vw, 2.5rem);
  }
  .quote {
    margin: 0;
    padding: 2.4rem 2rem;
    border: 1px solid var(--line);
    background: var(--paper-2);
    border-radius: 3px;
    position: relative;
    display: flex;
    flex-direction: column;
    transition: transform 0.5s cubic-bezier(0.16, 1, 0.3, 1), box-shadow 0.5s ease;
  }
  .quote:hover {
    transform: translateY(-4px);
    box-shadow: 0 24px 50px -28px rgba(0, 0, 0, 0.45);
  }
  .quote__mark {
    font-family: var(--font-display);
    font-size: 4.5rem;
    line-height: 0.5;
    color: var(--accent-2);
    height: 1.4rem;
    display: block;
  }
  .quote__text {
    margin: 1.6rem 0 0;
    font-family: var(--font-display);
    font-weight: 360;
    font-size: 1.2rem;
    line-height: 1.45;
    color: var(--ink);
    flex: 1;
  }
  .quote__cite {
    margin-top: 1.8rem;
    padding-top: 1.2rem;
    border-top: 1px solid var(--line);
    font-style: normal;
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }
  .quote__author {
    font-weight: 500;
    font-size: 0.98rem;
  }
  .quote__context {
    font-size: 0.8rem;
    color: var(--ink-faint);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  @media (max-width: 900px) {
    .tst__grid {
      grid-template-columns: 1fr;
      max-width: 38rem;
    }
  }
</style>

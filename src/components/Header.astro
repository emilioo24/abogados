---
import { site } from "@config/site";
const { brand, nav, hero } = site;
---

<header class="hdr" id="top">
  <div class="container hdr__inner">
    <a href="#top" class="brand" aria-label={`${brand.name}, inicio`}>
      <span class="brand__mono">{brand.monogram}</span>
      <span class="brand__text">
        <span class="brand__name">{brand.name}</span>
        <span class="brand__tag">{brand.tagline}</span>
      </span>
    </a>

    <nav class="nav" aria-label="Principal">
      {nav.map((l) => (
        <a href={l.href} class="nav__link link-underline">{l.label}</a>
      ))}
    </nav>

    <div class="hdr__actions">
      <a href={hero.primaryCta.href} class="btn hdr__cta">{hero.primaryCta.label}</a>
      <button class="burger" aria-label="Abrir menú" aria-expanded="false" data-burger>
        <span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Menú móvil -->
  <div class="mobile" data-mobile hidden>
    <nav class="mobile__nav" aria-label="Móvil">
      {nav.map((l) => <a href={l.href} class="mobile__link">{l.label}</a>)}
      <a href={hero.primaryCta.href} class="btn mobile__cta">{hero.primaryCta.label}</a>
    </nav>
  </div>
</header>

<style>
  .hdr {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--paper) 82%, transparent);
    backdrop-filter: blur(12px) saturate(1.1);
    border-bottom: 1px solid var(--line);
  }
  .hdr__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    height: 5rem;
  }
  .brand {
    display: flex;
    align-items: center;
    gap: 0.8rem;
  }
  .brand__mono {
    font-family: var(--font-display);
    font-weight: 500;
    font-size: 1.15rem;
    letter-spacing: 0.02em;
    width: 2.6rem;
    height: 2.6rem;
    display: grid;
    place-items: center;
    border: 1px solid var(--line-strong);
    border-radius: 50%;
    color: var(--accent);
    flex-shrink: 0;
  }
  .brand__text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }
  .brand__name {
    font-family: var(--font-display);
    font-size: 1.18rem;
    font-weight: 480;
    letter-spacing: -0.01em;
  }
  .brand__tag {
    font-size: 0.72rem;
    color: var(--ink-faint);
    letter-spacing: 0.02em;
  }
  .nav {
    display: flex;
    gap: clamp(1rem, 2.4vw, 2.4rem);
    margin-inline: auto;
  }
  .nav__link {
    font-size: 0.92rem;
    color: var(--ink-soft);
    transition: color 0.3s ease;
  }
  .nav__link:hover {
    color: var(--ink);
  }
  .hdr__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }
  .hdr__cta {
    padding: 0.7em 1.3em;
    font-size: 0.88rem;
  }
  .burger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    padding: 0.5rem;
  }
  .burger span {
    width: 24px;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.35s ease, opacity 0.35s ease;
  }
  .burger[aria-expanded="true"] span:first-child {
    transform: translateY(6.5px) rotate(45deg);
  }
  .burger[aria-expanded="true"] span:last-child {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .mobile {
    border-bottom: 1px solid var(--line);
    background: var(--paper);
    overflow: hidden;
  }
  .mobile__nav {
    display: flex;
    flex-direction: column;
    padding: 1rem clamp(1.25rem, 4vw, 3.5rem) 2rem;
    gap: 0.2rem;
  }
  .mobile__link {
    font-family: var(--font-display);
    font-size: 1.5rem;
    padding: 0.6rem 0;
    border-bottom: 1px solid var(--line);
  }
  .mobile__cta {
    margin-top: 1.2rem;
    justify-content: center;
  }

  @media (max-width: 880px) {
    .nav,
    .hdr__cta {
      display: none;
    }
    .burger {
      display: flex;
    }
  }
</style>

<script>
  const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
  const mobile = document.querySelector<HTMLElement>("[data-mobile]");
  burger?.addEventListener("click", () => {
    const open = burger.getAttribute("aria-expanded") === "true";
    burger.setAttribute("aria-expanded", String(!open));
    if (mobile) mobile.hidden = open;
  });
  mobile?.querySelectorAll("a").forEach((a) =>
    a.addEventListener("click", () => {
      burger?.setAttribute("aria-expanded", "false");
      if (mobile) mobile.hidden = true;
    })
  );
</script>

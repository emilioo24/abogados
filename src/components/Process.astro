---
import { site } from "@config/site";
const { process } = site;
---

<section class="section on-dark process" id="metodo">
  <div class="container">
    <div class="process__head" data-reveal>
      <p class="eyebrow">{process.eyebrow}</p>
      <h2 class="display-lg">{process.title}</h2>
      <p class="lead process__intro">{process.intro}</p>
    </div>

    <ol class="steps">
      {process.steps.map((step, i) => (
        <li class="step" data-reveal style={`--reveal-delay:${i * 0.1}s`}>
          <span class="step__num">{String(i + 1).padStart(2, "0")}</span>
          <div class="step__body">
            <h3 class="step__title">{step.title}</h3>
            <p class="step__desc">{step.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>

<style>
  .process__head {
    max-width: 56ch;
    margin-bottom: clamp(2.5rem, 5vw, 4.5rem);
  }
  .process__head h2 {
    margin-top: 1.3rem;
  }
  .process__intro {
    margin-top: 1.5rem;
  }
  .steps {
    list-style: none;
    padding: 0;
    margin: 0;
    counter-reset: step;
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .step {
    padding: 2rem 1.6rem 2.4rem 0;
    border-top: 1px solid var(--line-dark);
    position: relative;
  }
  .step__num {
    font-family: var(--font-display);
    font-size: 1rem;
    color: var(--gold);
    letter-spacing: 0.05em;
  }
  .step::after {
    /* marca de progreso superior */
    content: "";
    position: absolute;
    top: -1px;
    left: 0;
    width: 2.4rem;
    height: 2px;
    background: var(--gold);
  }
  .step__title {
    font-size: 1.5rem;
    margin-top: 2.2rem;
    color: var(--on-dark);
  }
  .step__desc {
    margin-top: 0.9rem;
    color: var(--on-dark-soft);
    font-size: 0.96rem;
    max-width: 30ch;
  }

  @media (max-width: 900px) {
    .steps {
      grid-template-columns: repeat(2, 1fr);
      gap: 0 2rem;
    }
  }
  @media (max-width: 520px) {
    .steps {
      grid-template-columns: 1fr;
    }
  }
</style>

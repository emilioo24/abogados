---
import { site } from "@config/site";
const { faq } = site;
---

<section class="section faq">
  <div class="container faq__inner">
    <div class="faq__head" data-reveal>
      <p class="eyebrow">{faq.eyebrow}</p>
      <h2 class="display-lg">{faq.title}</h2>
    </div>

    <div class="faq__list">
      {faq.items.map((item, i) => (
        <details class="qa" name="faq" open={i === 0} data-reveal style={`--reveal-delay:${i * 0.06}s`}>
          <summary class="qa__q">
            <span>{item.question}</span>
            <span class="qa__icon" aria-hidden="true"></span>
          </summary>
          <div class="qa__a">
            <p>{item.answer}</p>
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<style>
  .faq__inner {
    display: grid;
    grid-template-columns: 0.7fr 1.3fr;
    gap: clamp(2rem, 5vw, 5rem);
    align-items: start;
  }
  .faq__head {
    position: sticky;
    top: 7rem;
  }
  .faq__head h2 {
    margin-top: 1.3rem;
  }
  .faq__list {
    border-top: 1px solid var(--line-strong);
  }
  .qa {
    border-bottom: 1px solid var(--line);
  }
  .qa__q {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.5rem 0;
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-size: clamp(1.15rem, 1rem + 0.6vw, 1.5rem);
    font-weight: 420;
    color: var(--ink);
    transition: color 0.3s ease;
  }
  .qa__q::-webkit-details-marker {
    display: none;
  }
  .qa__q:hover {
    color: var(--accent);
  }
  .qa__icon {
    position: relative;
    width: 18px;
    height: 18px;
    flex-shrink: 0;
  }
  .qa__icon::before,
  .qa__icon::after {
    content: "";
    position: absolute;
    background: var(--accent-2);
    transition: transform 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .qa__icon::before {
    top: 50%;
    left: 0;
    width: 100%;
    height: 1.5px;
    transform: translateY(-50%);
  }
  .qa__icon::after {
    left: 50%;
    top: 0;
    height: 100%;
    width: 1.5px;
    transform: translateX(-50%);
  }
  .qa[open] .qa__icon::after {
    transform: translateX(-50%) scaleY(0);
  }
  .qa__a {
    overflow: hidden;
    color: var(--ink-soft);
    padding-bottom: 1.6rem;
    max-width: 60ch;
    animation: qa-open 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  }
  @keyframes qa-open {
    from {
      opacity: 0;
      transform: translateY(-6px);
    }
  }

  @media (max-width: 820px) {
    .faq__inner {
      grid-template-columns: 1fr;
    }
    .faq__head {
      position: static;
    }
  }
</style>
